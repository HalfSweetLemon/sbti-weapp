.test-card {
  padding: 32rpx;
}

.question-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #dbe8dd;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff, #fbfdfb);
}

.question-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #edf6ef;
  color: #4d6a53;
  font-size: 22rpx;
}

.question-meta {
  color: #6a786f;
  font-size: 22rpx;
}

.question-title {
  color: #1e2a22;
  font-size: 30rpx;
  line-height: 1.75;
}

.option {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #dbe8dd;
  border-radius: 24rpx;
  background: #ffffff;
}

.option-code {
  color: #4d6a53;
  font-weight: 700;
}

.option-text {
  flex: 1;
  color: #1e2a22;
  line-height: 1.7;
}

.hint-text {
  display: block;
  margin-top: 8rpx;
  color: #6a786f;
  font-size: 24rpx;
  line-height: 1.7;
}

.actions-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 28rpx;
}

.action-button {
  flex: 1;
}

.card {}
.btn-primary {}
.btn-secondary {}
