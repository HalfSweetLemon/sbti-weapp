.result-card {
  padding: 32rpx;
}

.result-top {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-image {
  width: 100%;
  height: 440rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff, #f7fbf8);
}

.type-box {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx;
  border: 1rpx solid #dbe8dd;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff, #fbfdfb);
}

.type-kicker {
  color: #4d6a53;
  font-size: 24rpx;
}

.type-name {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
}

.match-badge {
  color: #4d6a53;
  font-size: 24rpx;
  font-weight: 700;
}

.type-sub,
.section-copy {
  color: #304034;
  font-size: 28rpx;
  line-height: 1.8;
}

.section-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #dbe8dd;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff, #fbfdfb);
}

.section-title {
  display: block;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.score-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.actions-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-button {
  flex: 1;
}

.card {}
.btn-primary {}
.btn-secondary {}
